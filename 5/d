<!DOCTYPE html>
<html>
<head>
<style>
.box {
    width: 300px;               /* Content */
    padding: 20px;              /* Padding */
    border: 5px solid blue;     /* Border */
    margin: 30px;               /* Margin */
    background-color: lightyellow;
}
</style>
</head>
<body>

<h2>CSS Box Model Example</h2>

<div class="box">
    This is the CONTENT area.<br>
    Padding adds space inside the box.<br>
    Border surrounds the padding.<br>
    Margin adds space outside the border.
</div>

</body>
</html>
